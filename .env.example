# GROQ_API_KEY / GROQ_API_KEY_2 / GROQ_API_KEY_3:
# Keys are tried in order for GPT-first routing (openai/gpt-oss-20b) for both weekly summarization and reply/delegate draft generation.
# If all keys fail on GPT, the app automatically falls back to secondary models; if those fail, it uses deterministic local fallback logic.
# Restart the Vite dev server after updating this value.
GROQ_API_KEY="your-groq-api-key"
GROQ_API_KEY_2="your-backup-groq-api-key"
GROQ_API_KEY_3="your-second-backup-groq-api-key"
# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://gmail-clone-ten-ruddy.vercel.app/"
